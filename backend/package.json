{
  "name": "@repo/root",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "prepare": "lefthook install",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck",
    "dev": "turbo dev",
    "migrate": "pnpm --filter @repo/db-adapter migrate",
    "seed": "pnpm --filter @repo/db-adapter seed"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "20.5.2",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/types": "20.5.0",
    "lefthook": "2.1.6",
    "madge": "8.0.0",
    "turbo": "2.9.6",
    "typescript": "5.7.3"
  },
  "packageManager": "pnpm@9.15.4"
}
