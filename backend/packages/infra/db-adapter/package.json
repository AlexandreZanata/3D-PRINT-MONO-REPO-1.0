{
  "name": "@repo/db-adapter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "migrate": "drizzle-kit migrate",
    "seed": "node dist/seed.js"
  },
  "dependencies": {
    "@repo/domain": "workspace:*",
    "@repo/utils": "workspace:*",
    "argon2": "0.41.1",
    "drizzle-orm": "0.36.4",
    "postgres": "3.4.9"
  },
  "devDependencies": {
    "@types/node": "22.10.7",
    "drizzle-kit": "0.28.1",
    "vitest": "2.1.8"
  }
}
