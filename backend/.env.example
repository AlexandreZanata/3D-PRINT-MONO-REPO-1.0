# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ecommerce
POSTGRES_USER=postgres
# SECURITY: never commit the real value
POSTGRES_PASSWORD=change_me

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# SECURITY: never commit the real value
REDIS_PASSWORD=change_me

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_USER=guest
# SECURITY: never commit the real value
RABBITMQ_PASSWORD=change_me

# ─── JWT (RS256) ──────────────────────────────────────────────────────────────
# SECURITY: load from a secrets manager in production; never commit real keys
JWT_PRIVATE_KEY_PATH=./secrets/jwt.private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt.public.pem
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# ─── Admin security ───────────────────────────────────────────────────────────
# Comma-separated list of allowed IPs for admin routes
ADMIN_ALLOWED_IPS=127.0.0.1,::1

# ─── SSE ──────────────────────────────────────────────────────────────────────
SSE_MAX_CONNECTIONS=500

# ─── Service ports ────────────────────────────────────────────────────────────
API_GATEWAY_PORT=3000
PRODUCT_SERVICE_PORT=3001
ADMIN_SERVICE_PORT=3002
NOTIFICATION_SERVICE_PORT=3003

# ─── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
