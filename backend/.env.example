# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# PostgreSQL 18.1+ required for native UUIDv7 support (gen_random_uuid_v7)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ecommerce
POSTGRES_USER=postgres
# SECURITY: never commit the real value
POSTGRES_PASSWORD=change_me

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# SECURITY: never commit the real value
REDIS_PASSWORD=change_me

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_USER=guest
# SECURITY: never commit the real value
RABBITMQ_PASSWORD=change_me

# ─── JWT (RS256) ──────────────────────────────────────────────────────────────
# SECURITY: load from a secrets manager in production; never commit real keys
JWT_PRIVATE_KEY_PATH=./secrets/jwt.private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt.public.pem
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# ─── Admin security ───────────────────────────────────────────────────────────
# Comma-separated allowlist: exact IPs (after ::ffff normalization) and/or IPv4 CIDR (e.g. 172.16.0.0/12 for Docker bridge)
ADMIN_ALLOWED_IPS=127.0.0.1,::1,172.16.0.0/12
# Set to 0 to stop auto-appending 172.16.0.0/12 when ADMIN_ALLOWED_IPS is set (strict prod)
# ADMIN_ALLOW_DOCKER_BRIDGE=0
# Express trust proxy hops (X-Forwarded-For) when behind api-gateway
ADMIN_TRUST_PROXY_HOPS=1
# Writable directory for admin image uploads (default: <cwd>/data/uploads)
# ADMIN_UPLOAD_DIR=/var/lib/forma/uploads

# ─── SSE ──────────────────────────────────────────────────────────────────────
SSE_MAX_CONNECTIONS=500

# ─── Service ports ────────────────────────────────────────────────────────────
API_GATEWAY_PORT=3000
PRODUCT_SERVICE_PORT=3001
ADMIN_SERVICE_PORT=3002
NOTIFICATION_SERVICE_PORT=3003

# ─── api-gateway upstream (never set these to the gateway URL) ───────────────
# PRODUCT_SERVICE_URL=http://localhost:3001
# ADMIN_SERVICE_URL=http://localhost:3002

# ─── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
