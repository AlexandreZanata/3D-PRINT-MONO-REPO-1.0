# ─── Backend API ─────────────────────────────────────────────────────────────
# URL of the api-gateway (backend entry point)
VITE_API_BASE_URL=http://localhost:3000

# Full SSE endpoint URL for real-time product updates
VITE_SSE_URL=http://localhost:3000/api/v1/products/events

# ─── App metadata ─────────────────────────────────────────────────────────────
# Injected at build time from package.json
VITE_APP_VERSION=$npm_package_version
