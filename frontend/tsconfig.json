{
  // Extends the monorepo frontend base — browser-compatible strict TypeScript.
  // See /tsconfig.frontend.base.json for the shared settings.
  "extends": "../tsconfig.frontend.base.json",
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.ts",
    "vitest.config.ts"
  ],
  "exclude": [
    "src/atoms/ui",
    "src/components/ui"
  ],
  "compilerOptions": {
    "paths": {
      // Import alias — "@/" maps to "src/" so no relative ../../../ imports
      "@/*": ["./src/*"],

      // @repo/contracts types shared from the backend monorepo (built dist)
      // Only contracts is needed on the frontend — no server-side packages
      "@repo/contracts": ["../backend/packages/contracts/dist/index.d.ts"],
      "@repo/contracts/*": ["../backend/packages/contracts/dist/*"]
    }
  }
}
